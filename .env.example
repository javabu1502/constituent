# =============================================================================
# My Democracy — Environment Variables
# Copy this file to .env.local and fill in the values.
# =============================================================================

# ---------------------------------------------------------------------------
# Required — the app will not start without these
# ---------------------------------------------------------------------------

# Anthropic Claude API key for AI message generation and chat
ANTHROPIC_API_KEY=

# Congress.gov API key — https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# Google Maps API key for address autocomplete and geocoding
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# Optional — features degrade gracefully without these
# ---------------------------------------------------------------------------

# Claude model override (defaults to claude-sonnet-4-20250514)
# CLAUDE_MODEL=

# FEC API key for campaign finance data — https://api.open.fec.gov/developers/
# Without this, the Funding tab on rep profiles will show "not available"
# FEC_API_KEY=

# LegiScan API key for state legislation — https://legiscan.com/legiscan
# LEGISCAN_API_KEY=

# Open States API key for state legislature data — https://openstates.org/accounts/signup/
# OPENSTATES_API_KEY=

# Cloudflare Turnstile CAPTCHA
# If not set, form submissions bypass CAPTCHA verification (dev mode)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Resend email service — https://resend.com
# If not set, digest emails and notifications are skipped silently
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@mydemocracy.app

# Secret for cron jobs (digest emails) and unsubscribe token HMAC
# If not set, a default secret is used (not secure for production)
# CRON_SECRET=

# Census Bureau API key — https://api.census.gov/data/key_signup.html
# If not set, Census API still works but may be rate-limited at high traffic
# CENSUS_API_KEY=
